#include <cs50.h>
#include <ctype.h>
#include <stdbool.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
int main()
{
    int n;
    printf("What would you like to do\n");
    printf("1.Encrypt\n");
    printf("2.Decrypt\n");
    int ch = get_int("enter choice:");
    string msg = get_string("enter message:");
    int k = get_int("enter key:");
    char c;
    n=strlen(msg);


    if (ch==1)
    {
        printf("Encrypted:");
        for(int i=0;i<n;i++)
        {
            c = msg[i];
            if(isupper(c))
            {
                c=(((c-'A')+k)%26)+'A';
                printf("%c",c);
            }else if(islower(c))
            {
                c=(((c-'a')+k)%26)+'a';
                printf("%c",c);
            }else{
                printf("%c",c);

            }

        }
        printf("\n");

    }else if (ch==2)
    {
        printf("Decrypted:");
        for(int i=0;i<n;i++)
        {
             c= msg[i];
               if(isupper(c))
            {
                c=(((c-'A')-k+26)%26)+'A';
                printf("%c",c);
            }else if(islower(c))
            {
                c=(((c-'a')-k+26)%26)+'a';
                printf("%c",c);
            }else{
                printf("%c",c);

            }

        }
        printf("\n");
    }


}
