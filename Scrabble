#include <cs50.h>
#include <ctype.h>
#include <stdio.h>
#include <string.h>
int calculate(string s3, int points[]);
int main()
{
    int points[] = {1, 3, 3, 2, 1, 4, 2, 4, 1, 8, 5, 1, 3, 1, 1, 3, 10, 1, 1, 1, 1, 4, 4, 8, 4, 10};
    string s1 = get_string("Player 1:\n");
    string s2 = get_string("Player 2:\n");
    int sum1 = calculate(s1, points);
    int sum2 = calculate(s2, points);

    if (sum1 > sum2)
    {
        printf("Player 1 Wins!\n");
    }
    else if (sum2 > sum1)
    {
        printf("Player 2 Wins!\n");
    }
    else
    {
        printf("Tie\n");
    }
}

int calculate(string s3, int points[])
{
    int sum = 0, pos;
    for (int i = 0, n = strlen(s3); i < n; i++)
    {
        if (isalpha(s3[i]))
        {
            char c = toupper(s3[i]);
            pos = c - 'A';
            sum += points[pos];
        }
    }
    return sum;
}
