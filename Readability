#include <cs50.h>
#include <ctype.h>
#include <math.h>
#include <stdbool.h>
#include <stdio.h>
#include <stdlib.h>
#include <string.h>
int main()
{
    string input = get_string("Text\n");
    int len = strlen(input);
    int i;
    int nw = 1;
    int ns = 0;
    int nl = 0;
    for (i = 0; i < len; i++)
    {
        char ch = input[i];
        if (ch == ' ')
        {
            nw++;
        }
        else if (ch == '.' || ch == '!' || ch == '?')
        {
            ns++;
        }

        if (isalpha(ch))
        {
            nl++;
        }
    }
    double l = (double) nl / nw * 100;
    double s = (double) ns / nw * 100;

    double index = 0.0588 * l - 0.296 * s - 15.8;
    if (index > 16)
    {
        printf("Grade 16+\n");
    }
    else if (index < 1)
    {
        printf("Before Grade 1\n");
    }
    else
    {
        printf("Grade %i\n", (int) round(index));
    }
}
